# No notebooks — per project rules (no incomplete notebooks with arbitrary executions)
*.ipynb
.ipynb_checkpoints/

# No model weights or datasets
saved_models/
*.pt
*.pth
*.bin
*.safetensors
*.h5
*.pkl
*.csv
*.json
!**/results/results.json

# Keep compiled report, presentation PDFs, and root spec
*.pdf
!report/*.pdf
!presentation/*.pdf

# LaTeX artifacts
*.aux
*.log
*.out
*.toc
*.nav
*.snm
*.fls
*.fdb_latexmk

# Python
__pycache__/
*.pyc
*.pyo
.env
venv/
